-- Effets survol
local function addHoverEffect(btn, normalColor, hoverColor)
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = hoverColor
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = normalColor
    end)
end

addHoverEffect(btnBoth, Color3.fromRGB(0, 170, 255), Color3.fromRGB(0, 130, 220))
addHoverEffect(btnKeyboard, Color3.fromRGB(255, 100, 100), Color3.fromRGB(220, 70, 70))

-- === PREMIER BOUTON : Les deux scripts ===
btnBoth.MouseButton1Click:Connect(function()
    pcall(function()
        loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-grab-knife-v3-112292"))()
        print("✅ Grab Knife V3 chargé")
